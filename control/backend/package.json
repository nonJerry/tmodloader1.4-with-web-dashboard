{
    "name": "@terraria-podman/control-backend",
    "version": "0.1.0",
    "type": "module",
    "packageManager": "pnpm@11.8.0",
    "scripts": {
        "build": "tsc",
        "start": "tsc && node dist/index.js",
        "start-watch": "pnx tsx watch src/index.ts",
        "dev": "cross-env NODE_ENV=development pnx tsx watch src/index.ts",
        "test": "vitest",
        "test:ci": "vitest run",
        "lint": "oxlint . --fix"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "connect-redis": "^9.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "csrf-csrf": "^4.0.3",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.3",
        "redis": "^6.0.0",
        "undici": "^8.4.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mock-fs": "^4.13.4",
        "@types/node": "^24.13.2",
        "@types/supertest": "^7.2.0",
        "mock-fs": "^5.5.0",
        "nodemon": "^3.1.14",
        "oxlint": "^1.69.0",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "allowScripts": {
        "bcrypt@6.0.0": true,
        "@parcel/watcher@2.5.6": true
    }
}