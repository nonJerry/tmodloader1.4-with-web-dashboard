{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": [
        "eslint",
        "typescript",
        "unicorn",
        "oxc"
    ],
    "categories": {
        "correctness": "error"
    },
    "rules": {
        "no-unused-vars": [
            "error",
            {
                "caughtErrors": "all",
                "caughtErrorsIgnorePattern": "^ignored"
            }
        ]
    }
}