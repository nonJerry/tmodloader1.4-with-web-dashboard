{
  "name": "terraria-podman",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "version": "0.1.0",
  "workspaces": [
    "control/backend",
    "control/frontend"
  ],
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:backend": "pnpm --filter @terraria-podman/control-backend dev",
    "dev:frontend": "pnpm --filter @terraria-podman/control-frontend dev",
    "full-stack": "cd dev && podman compose up --build -d",
    "full-stack:docker": "cd dev && docker compose up --build -d",
    "full-stack-no-build:docker": "cd dev && docker compose up",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test:ci",
    "test:e2e": "pnpm --filter @terraria-podman/control-frontend test:e2e ",
    "test:frontend": "pnpm --filter @terraria-podman/control-frontend test",
    "test:backend": "pnpm --filter @terraria-podman/control-backend test",
    "e2e": "pnpm full-stack:docker && pnpm test:e2e",
    "lint": "pnpm -r lint",
    "lint:backend": "pnpm --filter @terraria-podman/control-backend lint",
    "lint:frontend": "pnpm --filter @terraria-podman/control-frontend lint"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.9",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "jsonc-parser": "^3.3.1",
    "oxlint": "^1.69.0"
  },
  "overrides": {
    "glob": "^13.0.6"
  }
}
